# Copy to pair-verify.env (gitignored) to enable the in-sandbox verify-pair-flow
# step. host-orchestrator.sh stages it RO into the sandbox; the WSL runner loads
# it via PAIR_VERIFY_ENV. Without it, the step records status 'skip'.
#
#   ⚠️  The service_role JWT bypasses RLS — treat it like a root password.
SUPABASE_URL=https://api.agent-control.io
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SERVICE_ROLE_JWT
APP_URL=https://app.agent-control.io
TEST_EMAIL=e2e-installer-test@agentcontrol.dev
CLAIM_CODE=TEST-0000
LABEL=e2e-verify
# Optional — only when driving a real pairing and the bridge is reachable:
# BRIDGE_PAIR_URL=http://127.0.0.1:3001/pair
