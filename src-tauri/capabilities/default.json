{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window — Login + Settings + Pairing + Status",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-close",
    "opener:default",
    "notification:default",
    "store:default",
    "deep-link:default",
    "updater:default",
    "process:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://localhost:*/*" },
        { "url": "http://127.0.0.1:*/*" },
        { "url": "https://*.supabase.co/*" },
        { "url": "https://*/*" }
      ]
    }
  ]
}
