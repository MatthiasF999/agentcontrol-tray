{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "agentcontrol-tray",
  "version": "0.7.5",
  "identifier": "dev.agentcontrol.tray",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AgentControl",
        "width": 960,
        "height": 640,
        "minWidth": 720,
        "minHeight": 480,
        "visible": true,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "/home/**",
          "/Users/**",
          "/tmp/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "deb", "appimage"],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installerHooks": "installer-hooks.nsh"
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["agentcontrol-tray"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/MatthiasF999/agentcontrol-tray/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRBQkIyRTIxREFEMzU0ODkKUldTSlZOUGFJUzY3U3NnUFpSQVUrVno4akgrNWNzT3llOGx0elBiV0RkYlUrcWM4NlVCTDVCVk0K"
    }
  }
}
